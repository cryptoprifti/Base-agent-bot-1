{
  "buildCommand": "cd artifacts/basebot && pnpm run build && cp -r dist/public ../../public",
  "outputDirectory": "public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/.well-known/(.*)", "destination": "/.well-known/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
